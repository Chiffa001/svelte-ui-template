    "lint-stage": "npm run lint && npm run check && npm run test && npm run build",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "eslint": "^10.1.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-svelte": "^3.11.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "svelte": "^5.53.12",
    "svelte-check": "^4.4.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.28.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.1"
  }
}
